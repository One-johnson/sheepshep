# Convex (local dev: use .env.local with values from `npx convex dev`)
# For Vercel production: set these in Vercel → Settings → Environment Variables
# - CONVEX_DEPLOY_KEY: from Convex Dashboard → Settings → Production Deploy Key
# - NEXT_PUBLIC_CONVEX_URL: your production Convex URL (e.g. https://<deployment>.convex.cloud)
CONVEX_DEPLOY_KEY=
NEXT_PUBLIC_CONVEX_URL=https://colorful-lapwing-750.convex.cloud

# Web Push (set the same VAPID keys in Convex Dashboard → Settings → Environment Variables)
# Generate: npx web-push generate-vapid-keys
# VAPID_SUBJECT is usually mailto:your-email@domain.com (required by push services)
VAPID_PUBLIC_KEY=BBe5wMrnQ0yegtEdAxeyDJ9UZ0X902JhiSjYp6PdVdbOOXPgs-N1DjGvREwaCK5XpUcSrHtjSww-EbPXjSix6Qs
VAPID_PRIVATE_KEY=IMAAL5heAErktG3C7clpUPTPqk5neXCF_6IesT5VK8c
